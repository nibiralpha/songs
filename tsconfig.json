{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@app/*": ["./src/app/*"],
      "@redux/*": ["./src/redux/*"],
      "@Api/*": ["./src/app/Api/*"],
      "@Hooks/*": ["./src/app/Hooks/*"],
      "@Components/*": ["./src/app/Components/*"],
      "@app-types/*": ["./src/app/types/*"],
      "@Services/*": ["./src/app/Services/*"],
      "@Constant/*": ["./src/app/Constant/*"],
      "@Helper/*": ["./src/app/Helper/*"],
      "@search/*": ["./src/app/search/*"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
